# -------------------------------------------------------
# The ONLY key you need to provide to run this project
# -------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# HL OAuth — pre-configured on Railway, needed for local dev
HL_CLIENT_ID=
HL_CLIENT_SECRET=
HL_REDIRECT_URI=http://localhost:3000/redirect

# Optional overrides
SESSION_SECRET=replace-with-random-string
PORT=3000
NUM_TEST_CASES=2
MAX_TURNS_PER_CASE=15
PER_CASE_TIMEOUT_MS=120000
SIMULATION_TIMEOUT_MS=660000
MAX_OPTIMIZE_ATTEMPTS=2
